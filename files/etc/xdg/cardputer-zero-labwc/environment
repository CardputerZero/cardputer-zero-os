# Cardputer Zero internal labwc session.
#
# This configuration is for the internal Wayland/labwc session. It constrains
# wlroots/labwc to the internal SPI DRM panel instead of HDMI.

WLR_BACKENDS=drm,libinput
WLR_DRM_DEVICES=/dev/dri/cardputer-zero-internal
WLR_RENDERER=pixman

DESKTOP_SESSION=cardputer-zero-labwc
XDG_CURRENT_DESKTOP=CardputerZero
XDG_SESSION_DESKTOP=CardputerZero

XCURSOR_THEME=cardputer-zero-empty
XCURSOR_SIZE=1
