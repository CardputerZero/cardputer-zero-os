# Cardputer Zero device permissions.
# Users still need group membership or logind/uaccess support from the base OS.

SUBSYSTEM=="input", GROUP="input", MODE="0660", TAG+="uaccess"
# The internal Cardputer keyboard must be assigned at the input parent and
# event-node levels. logind reports seats from the parent input device, while
# libinput consumes the event node properties.
SUBSYSTEM=="input", ATTR{name}=="tca8418c", ENV{ID_INPUT}="1", ENV{ID_INPUT_KEYBOARD}="1", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat-cardputer-zero"
SUBSYSTEM=="input", KERNEL=="event*", ATTRS{name}=="tca8418c", ENV{ID_INPUT}="1", ENV{ID_INPUT_KEYBOARD}="1", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat-cardputer-zero"
SUBSYSTEM=="video4linux", GROUP="video", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="drm", KERNEL=="card*", GROUP="video", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="drm", KERNEL=="controlD*", GROUP="video", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="drm", KERNEL=="renderD*", GROUP="render", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="drm", KERNEL=="card*", ENV{ID_PATH}=="platform-3f204000.spi-cs-0", SYMLINK+="dri/cardputer-zero-internal", TAG+="seat", TAG+="master-of-seat", ENV{ID_SEAT}="seat-cardputer-zero"
SUBSYSTEM=="drm", KERNEL=="card*", ENV{ID_PATH}=="platform-soc:gpu", SYMLINK+="dri/cardputer-zero-hdmi"
SUBSYSTEM=="drm", KERNEL=="card*-HDMI-A-*", ACTION=="change", TAG+="systemd", ENV{SYSTEMD_WANTS}+="zero-hdmi-lightdm-policy.service"
SUBSYSTEM=="sound", GROUP="audio", MODE="0660", TAG+="uaccess"

KERNEL=="gpiomem", GROUP="gpio", MODE="0660"
SUBSYSTEM=="gpio", GROUP="gpio", MODE="0660"
KERNEL=="gpiochip*", GROUP="gpio", MODE="0660"

KERNEL=="spidev*", GROUP="spi", MODE="0660"
KERNEL=="i2c-*", GROUP="i2c", MODE="0660"
