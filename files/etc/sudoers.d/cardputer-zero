# Restricted privileged helper access for Cardputer Zero users.
# The helper itself whitelists subcommands and must not execute arbitrary shell.

%cardputer-zero ALL=(root) NOPASSWD: /usr/local/sbin/zero-helper reboot
%cardputer-zero ALL=(root) NOPASSWD: /usr/local/sbin/zero-helper shutdown
%cardputer-zero ALL=(root) NOPASSWD: /usr/local/sbin/zero-helper poweroff
%cardputer-zero ALL=(root) NOPASSWD: /usr/local/sbin/zero-helper restart-greeter
%cardputer-zero ALL=(root) NOPASSWD: /usr/local/sbin/zero-helper network-restart
%cardputer-zero ALL=(root) NOPASSWD: /usr/local/sbin/zero-helper display internal
%cardputer-zero ALL=(root) NOPASSWD: /usr/local/sbin/zero-helper display mirror
%cardputer-zero ALL=(root) NOPASSWD: /usr/local/sbin/zero-helper display extended
