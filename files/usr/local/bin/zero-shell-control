#!/bin/sh
set -eu

runtime_dir=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}
wayland_display=${WAYLAND_DISPLAY:-wayland-0}

export XDG_RUNTIME_DIR=$runtime_dir
export WAYLAND_DISPLAY=$wayland_display

command_file=$runtime_dir/zero-shell-command
agent_socket=${ZERO_WINDOW_AGENT_SOCKET:-$runtime_dir/cardputer-zero/window-agent.sock}

fail() {
  printf 'zero-shell-control: %s\n' "$1" >&2
  exit 1
}

send_shell_command() {
  command=$1
  umask 077
  printf '%s\n' "$command" >"$command_file.tmp"
  mv "$command_file.tmp" "$command_file"
}

focus_shell() {
  agent_command focus-shell >/dev/null 2>&1 || fail "zero-window-agent cannot focus Shell"
}

shell_is_active() {
  agent_command active-is-shell >/dev/null 2>&1
}

agent_command() {
  command=$1
  [ -S "$agent_socket" ] || return 1
  python3 - "$agent_socket" "$command" <<'PY'
import socket
import sys

sock_path, command = sys.argv[1], sys.argv[2]
with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
    sock.settimeout(1.5)
    sock.connect(sock_path)
    sock.sendall((command + "\n").encode("utf-8"))
    data = b""
    while b"\n" not in data:
        chunk = sock.recv(4096)
        if not chunk:
            break
        data += chunk
line = data.decode("utf-8", errors="replace").splitlines()[0] if data else ""
raise SystemExit(0 if line.startswith("ok\t") else 1)
PY
}

case "${1:-}" in
  tasks)
    focus_shell
    send_shell_command toggle-tasks
    ;;
  hide-tasks)
    send_shell_command hide-tasks
    ;;
  focus-shell)
    focus_shell
    ;;
  minimize-active)
    if shell_is_active; then
      send_shell_command hide-tasks
      exit 0
    fi
    agent_command minimize-active >/dev/null 2>&1 || fail "zero-window-agent cannot minimize active task"
    sleep 0.05
    focus_shell
    send_shell_command hide-tasks
    ;;
  close-active)
    if shell_is_active; then
      send_shell_command hide-tasks
      exit 0
    fi
    agent_command close-active >/dev/null 2>&1 || fail "zero-window-agent cannot close active task"
    sleep 0.15
    focus_shell
    send_shell_command hide-tasks
    ;;
  *)
    cat >&2 <<'EOF'
usage: zero-shell-control tasks|hide-tasks|focus-shell|minimize-active|close-active
EOF
    exit 2
    ;;
esac
