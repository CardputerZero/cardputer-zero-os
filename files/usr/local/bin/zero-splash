#!/bin/sh
set -eu

WIDTH=${CARDPUTER_ZERO_FB_WIDTH:-320}
HEIGHT=${CARDPUTER_ZERO_FB_HEIGHT:-170}
ROTATION=${CARDPUTER_ZERO_FB_ROTATION:-auto}

python3 - "$WIDTH" "$HEIGHT" "$ROTATION" <<'PY'
import mmap
import os
import struct
import sys

width = int(sys.argv[1])
height = int(sys.argv[2])
rotation_arg = sys.argv[3]

def read_text(path):
    try:
        with open(path, "r", encoding="utf-8") as fh:
            return fh.read().strip()
    except OSError:
        return ""

def is_internal_name(name):
    return (
        "fb_st7789" in name
        or "st7789" in name
        or "panel-mipi-dbi" in name
        or "panel-mipi-dbid" in name
    )

def resolve_fb():
    env_fb = os.environ.get("CARDPUTER_ZERO_FB")
    if env_fb:
        return env_fb
    graphics = "/sys/class/graphics"
    try:
        entries = sorted(os.listdir(graphics))
    except OSError:
        entries = []
    for entry in entries:
        if not entry.startswith("fb") or entry == "fbcon":
            continue
        name = read_text(os.path.join(graphics, entry, "name"))
        if is_internal_name(name):
            return "/dev/" + entry
    return "/dev/fb0"

fb_path = resolve_fb()

if not os.access(fb_path, os.W_OK):
    print(f"zero-splash: framebuffer '{fb_path}' is not writable.", file=sys.stderr)
    raise SystemExit(0)

def rgb565(r, g, b):
    return ((r & 0xF8) << 8) | ((g & 0xF8) << 3) | (b >> 3)

font = {
    " ": [0,0,0,0,0], "0":[0x3e,0x51,0x49,0x45,0x3e], "1":[0,0x42,0x7f,0x40,0],
    "2":[0x42,0x61,0x51,0x49,0x46], "3":[0x21,0x41,0x45,0x4b,0x31],
    "4":[0x18,0x14,0x12,0x7f,0x10], "5":[0x27,0x45,0x45,0x45,0x39],
    "6":[0x3c,0x4a,0x49,0x49,0x30], "7":[0x01,0x71,0x09,0x05,0x03],
    "8":[0x36,0x49,0x49,0x49,0x36], "9":[0x06,0x49,0x49,0x29,0x1e],
    "A":[0x7e,0x11,0x11,0x11,0x7e], "C":[0x3e,0x41,0x41,0x41,0x22],
    "D":[0x7f,0x41,0x41,0x22,0x1c], "E":[0x7f,0x49,0x49,0x49,0x41],
    "G":[0x3e,0x41,0x49,0x49,0x7a], "I":[0,0x41,0x7f,0x41,0],
    "N":[0x7f,0x04,0x08,0x10,0x7f], "O":[0x3e,0x41,0x41,0x41,0x3e],
    "P":[0x7f,0x09,0x09,0x09,0x06], "R":[0x7f,0x09,0x19,0x29,0x46],
    "S":[0x46,0x49,0x49,0x49,0x31], "T":[0x01,0x01,0x7f,0x01,0x01],
    "U":[0x3f,0x40,0x40,0x40,0x3f], "Z":[0x61,0x51,0x49,0x45,0x43],
    "a":[0x20,0x54,0x54,0x54,0x78], "d":[0x38,0x44,0x44,0x48,0x7f],
    "e":[0x38,0x54,0x54,0x54,0x18], "g":[0x0c,0x52,0x52,0x52,0x3e],
    "i":[0,0x44,0x7d,0x40,0], "l":[0,0x41,0x7f,0x40,0],
    "n":[0x7c,0x08,0x04,0x04,0x78], "o":[0x38,0x44,0x44,0x44,0x38],
    "p":[0x7c,0x14,0x14,0x14,0x08], "r":[0x7c,0x08,0x04,0x04,0x08],
    "s":[0x48,0x54,0x54,0x54,0x20], "t":[0x04,0x3f,0x44,0x40,0x20],
    "u":[0x3c,0x40,0x40,0x20,0x7c], "z":[0x44,0x64,0x54,0x4c,0x44],
}

def put(buf, x, y, color):
    if 0 <= x < width and 0 <= y < height:
        px, py = map_point(x, y)
        if not (0 <= px < physical_width and 0 <= py < physical_height):
            return
        off = ((py * stride_pixels) + px) * 2
        buf[off:off + 2] = struct.pack("<H", color)

def rect(buf, x, y, w, h, color):
    line = struct.pack("<H", color) * max(0, w)
    for yy in range(y, y + h):
        if 0 <= yy < height:
            start = ((yy * width) + max(0, x)) * 2
            end = ((yy * width) + min(width, x + w)) * 2
            if end > start:
                buf[start:end] = line[:end - start]

def text(buf, x, y, value, color, scale=1):
    cx = x
    for ch in value:
        glyph = font.get(ch, font[" "])
        for col, bits in enumerate(glyph):
            for row in range(7):
                if bits & (1 << row):
                    rect(buf, cx + col * scale, y + row * scale, scale, scale, color)
        cx += 6 * scale

mode_text = read_text(f"/sys/class/graphics/{os.path.basename(fb_path)}/virtual_size")
if "," in mode_text:
    physical_width, physical_height = [int(part) for part in mode_text.split(",", 1)]
else:
    physical_width, physical_height = width, height

stride_text = read_text(f"/sys/class/graphics/{os.path.basename(fb_path)}/stride")
try:
    stride_pixels = int(stride_text) // 2 if stride_text else physical_width
except ValueError:
    stride_pixels = physical_width

if rotation_arg == "auto":
    rotation = 270 if physical_width == height and physical_height == width else 0
else:
    try:
        rotation = int(rotation_arg)
    except ValueError:
        rotation = 0

def map_point(x, y):
    if rotation == 90:
        return height - 1 - y, x
    if rotation == 270:
        return y, width - 1 - x
    return x, y

size = stride_pixels * physical_height * 2
with open(fb_path, "r+b", buffering=0) as fb:
    buf = mmap.mmap(fb.fileno(), size)
    for y in range(height):
        rect(buf, 0, y, width, 1, rgb565(8 + y // 8, 14 + y // 10, 28 + y // 4))
    rect(buf, 0, 0, width, 4, rgb565(80, 180, 255))
    rect(buf, 34, 42, 252, 72, rgb565(16, 27, 42))
    rect(buf, 34, 42, 252, 2, rgb565(80, 180, 255))
    rect(buf, 34, 112, 252, 2, rgb565(80, 180, 255))
    text(buf, 70, 58, "Cardputer Zero", rgb565(235, 242, 255), 2)
    text(buf, 96, 94, "Starting OS", rgb565(140, 245, 205), 1)
    buf.flush()
    buf.close()
PY
