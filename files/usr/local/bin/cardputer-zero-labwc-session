#!/bin/sh
set -eu

CONFIG=/etc/cardputer-zero/session.conf
LABWC_CONFIG_DIR=${CARDPUTER_ZERO_LABWC_CONFIG_DIR:-/etc/xdg/cardputer-zero-labwc}
LABWC_BIN=${CARDPUTER_ZERO_LABWC_BIN:-/usr/bin/labwc}

if [ -r "$CONFIG" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG"
fi

LABWC_CONFIG_DIR=${CARDPUTER_ZERO_LABWC_CONFIG_DIR:-$LABWC_CONFIG_DIR}
LABWC_BIN=${CARDPUTER_ZERO_LABWC_BIN:-$LABWC_BIN}

export XDG_SESSION_TYPE=wayland
export XDG_SEAT=${XDG_SEAT:-seat-cardputer-zero}
export XDG_CURRENT_DESKTOP=CardputerZero
export XDG_SESSION_DESKTOP=CardputerZero
export DESKTOP_SESSION=cardputer-zero-labwc
export CARDPUTER_ZERO_SESSION=1
export CARDPUTER_ZERO_LABWC_SESSION=1

: "${WLR_BACKENDS:=drm,libinput}"
: "${WLR_DRM_DEVICES:=/dev/dri/cardputer-zero-internal}"
: "${WLR_RENDERER:=pixman}"
: "${XCURSOR_THEME:=cardputer-zero-empty}"
: "${XCURSOR_SIZE:=1}"
: "${XKB_DEFAULT_RULES:=cardputerzero}"
: "${XKB_DEFAULT_MODEL:=pc105}"
: "${XKB_DEFAULT_LAYOUT:=cardputerzero}"
: "${XKB_DEFAULT_VARIANT:=}"
: "${XKB_DEFAULT_OPTIONS:=}"

export WLR_BACKENDS
export WLR_DRM_DEVICES
export WLR_RENDERER
export XCURSOR_THEME
export XCURSOR_SIZE
export XKB_DEFAULT_RULES
export XKB_DEFAULT_MODEL
export XKB_DEFAULT_LAYOUT
export XKB_DEFAULT_VARIANT
export XKB_DEFAULT_OPTIONS

if [ ! -x "$LABWC_BIN" ]; then
  printf 'cardputer-zero-labwc-session: labwc not found at %s\n' "$LABWC_BIN" >&2
  exit 127
fi

if [ ! -e "$WLR_DRM_DEVICES" ]; then
  printf 'cardputer-zero-labwc-session: internal DRM device not found: %s\n' "$WLR_DRM_DEVICES" >&2
  exit 1
fi

if [ ! -d "$LABWC_CONFIG_DIR" ]; then
  printf 'cardputer-zero-labwc-session: config dir not found: %s\n' "$LABWC_CONFIG_DIR" >&2
  exit 1
fi

if [ -n "${CARDPUTER_ZERO_WAYLAND_SHELL:-}" ] || [ -x /opt/cardputer-zero-shell/bin/zero-shell-wayland ]; then
  exec "$LABWC_BIN" -C "$LABWC_CONFIG_DIR" -S /usr/local/bin/cardputer-zero-shell-session
fi

cat >&2 <<'EOF'
cardputer-zero-labwc-session: no Wayland ZeroShell command configured.

Set CARDPUTER_ZERO_WAYLAND_SHELL in /etc/cardputer-zero/session.conf.
EOF

exit 127
