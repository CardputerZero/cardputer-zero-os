#!/bin/sh
set -eu

CONFIG=/etc/cardputer-zero/session.conf

export XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-wayland}
export XDG_CURRENT_DESKTOP=CardputerZero
export XDG_SESSION_DESKTOP=CardputerZero
export CARDPUTER_ZERO_SESSION=1

if [ -r "$CONFIG" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG"
fi

LABWC_SESSION=${CARDPUTER_ZERO_LABWC_SESSION:-/usr/local/bin/cardputer-zero-labwc-session}

if [ ! -x "$LABWC_SESSION" ]; then
  printf '\nCardputer Zero labwc session wrapper was not found:\n  %s\n\n' "$LABWC_SESSION" >&2
  exit 127
fi

exec "$LABWC_SESSION"
