#!/bin/sh
set -eu

CONFIG=/etc/cardputer-zero/session.conf

export XDG_SESSION_TYPE=tty
export XDG_CURRENT_DESKTOP=CardputerZero
export XDG_SESSION_DESKTOP=CardputerZero
export CARDPUTER_ZERO_SESSION=1

if [ -r "$CONFIG" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG"
fi

export CARDPUTER_ZERO_FB=${CARDPUTER_ZERO_FB:-/dev/fb1}
export ZEROSHELL_FBDEV=${ZEROSHELL_FBDEV:-$CARDPUTER_ZERO_FB}
export LV_LINUX_FBDEV_DEVICE=${LV_LINUX_FBDEV_DEVICE:-$CARDPUTER_ZERO_FB}
export APPLAUNCH_LINUX_FBDEV_DEVICE=${APPLAUNCH_LINUX_FBDEV_DEVICE:-$CARDPUTER_ZERO_FB}

SHELL_BIN=${CARDPUTER_ZERO_SHELL:-/opt/cardputer-zero-shell/bin/zero-shell}
POLKIT_AGENT=${CARDPUTER_ZERO_POLKIT_AGENT:-1}

start_zero_polkit_agent() {
  runtime_dir=${XDG_RUNTIME_DIR:-/tmp}
  session_id=${XDG_SESSION_ID:-session}
  pidfile="$runtime_dir/zero-polkit-agent.$session_id.pid"
  logfile="$runtime_dir/zero-polkit-agent.$session_id.log"

  if [ "$POLKIT_AGENT" != "1" ]; then
    return
  fi

  if [ ! -x /usr/local/bin/zero-polkit-agent ]; then
    return
  fi

  if [ -r "$pidfile" ]; then
    old_pid=$(cat "$pidfile" 2>/dev/null || true)
    if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
      return
    fi
  fi

  /usr/local/bin/zero-polkit-agent >>"$logfile" 2>&1 &
  echo "$!" >"$pidfile"
}

if [ ! -x "$SHELL_BIN" ]; then
  printf '\nCardputer Zero shell was not found:\n  %s\n\n' "$SHELL_BIN" >&2
  printf 'Starting a login shell for recovery.\n' >&2
  exec "${SHELL:-/bin/sh}" -l
fi

start_zero_polkit_agent
exec "$SHELL_BIN"
